---
import BaseLayout from "../layouts/BaseLayout.astro";
import { allIllustrations } from "../data/illustrations";

const title = "がっこうそざいラボ";
const description = "ログイン不要。小学校でそのまま使えるフリーイラスト素材サイト。";
---

<BaseLayout title={title} description={description}>

<h2>ようこそ</h2>

<p>
ログイン不要。小学校でそのまま使えるフリーイラスト素材サイトです。
</p>
<h2>新着イラスト</h2>

<div class="grid">
{allIllustrations.slice(-8).map((item) => (

<a class="card" href={`/illustration/${item.slug}`}>
<img src={item.png} alt={item.title} />
<p>{item.title}</p>
</a>

))}
</div>
<p>
  <a href="/illustration/">▶ イラスト一覧を見る</a>
</p>

<hr />

</BaseLayout>