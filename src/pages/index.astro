---
import BaseLayout from "../layouts/BaseLayout.astro";
import { allIllustrations } from "../data/illustrations";

const title = "がっこうそざいラボ";
const description = "ログイン不要。小学校でそのまま使えるフリーイラスト素材サイト。線画だけもダウンロードできます。";
---

<BaseLayout title={title} description={description}>

<h2>ようこそ</h2>

<p>
ログイン不要。小学校でそのまま使えるフリーイラスト素材サイトです。線画だけもダウンロードできます。
</p>
<h1>イラスト一覧</h1>
<div class="category-grid">
<a class="category-card" href="/illustration/character">
<h2>人物イラスト</h2>
<p>小学生の人物イラスト素材</p>
</a>
<a class="category-card" href="/illustration/item">
<h2>アイテムイラスト</h2>
<p>文房具や学校アイテム</p>
</a>

</div>
<h2>新着イラスト</h2>

<div class="grid">
{allIllustrations.slice(-8).map((item) => (

<a class="card" href={`/illustration/${item.slug}`}>
<img src={item.png} alt={item.title} />
<p>{item.title}</p>
</a>

))}
</div>


<hr />

</BaseLayout>