---
import BaseLayout from "../layouts/BaseLayout.astro";
import { allIllustrations } from "../data/illustrations";

const title = "がっこうそざいラボ";
const description =
  "ログイン不要。小学校でそのまま使えるフリーイラスト素材サイト。線画だけもダウンロードできます。";

const characterIllustrations = allIllustrations
  .filter((i) => i.character !== "item")
  .slice(-8)
  .reverse();

const itemIllustrations = allIllustrations
  .filter((i) => i.character === "item")
  .slice(-8)
  .reverse();
---

<BaseLayout title={title} description={description}>

<h1>小学校素材中心のフリーイラスト素材サイト</h1>
<p>
小学校・学級通信・授業プリントなどで使える無料イラスト。商用利用可能。ログイン不要。<br />
線画だけのイラストもあります。<br />
</p>
<div class="category-grid">
<a class="category-card" href="/illustration/character">
<h2>人物イラスト</h2>
<p>小学生の人物イラスト素材</p>
</a>
<a class="category-card" href="/illustration/item">
<h2>アイテムイラスト</h2>
<p>文房具や学校アイテム</p>
</a>
<a class="category-card" href="/illustration/giga">
<h2>GIGAスクール</h2>
<p>ICT関係の素材</p>
</a>

</div>
<h2 class="section-title">人物イラスト新着</h2>

<div class="grid">
{characterIllustrations.map((item) => (

<a class="card" href={`/illustration/${item.slug}`}>
<img src={item.png} alt={item.title} />
<p>{item.title}</p>
</a>

))}
</div>
<h2 class="section-title">アイテムイラスト新着</h2>

<div class="grid">
{itemIllustrations.map((item) => (
<a class="card" href={`/illustration/${item.slug}`}>
<img src={item.png} alt={item.title} />
<p>{item.title}</p>
</a>

))}
</div>


<hr />

</BaseLayout>