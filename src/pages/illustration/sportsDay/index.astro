---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { illustrations } from "@/data/illustrations";
import IllustrationCard from "@/components/IllustrationCard.astro";

const items = illustrations.filter(
  (item) => item.category.includes("sportsDay")
);
const title = "運動会イラスト";
const description = "小学校で使える運動会・体育のフリーイラスト素材です。おたよりや掲示物に。";
---

<BaseLayout title={title} description={description}>

<nav class="breadcrumb">
<a href="/">トップ</a>
<span>›</span>
<a href="/illustration">イラスト一覧</a>
<span>›</span>
<span>{title}</span>
</nav>

<h1 class="section-title">{title}</h1>
<p>{description}</p>

{items.length > 0 ? (
  <div class="grid">
    {items.map((item) => (
      <IllustrationCard item={item} />
    ))}
  </div>
) : (
  <p style="margin-top: 2rem; color: #666;">現在準備中です。</p>
)}

</BaseLayout>