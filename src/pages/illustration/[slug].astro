---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { illustrations  } from "../../data/illustrations";
import "../../styles/illustration.css";

export function getStaticPaths() {
  return illustrations .map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;

/* 同じポーズ */
const samePose = item.pose
  ? illustrations .filter(
      (i) => i.pose === item.pose && i.slug !== item.slug
    )
  : [];

/* 同じタグ */
const sameTag = item.tags?.[0]
  ? illustrations .filter(
      (i) =>
        i.tags?.includes(item.tags?.[0] ?? "") &&
        i.slug !== item.slug
    ).slice(0,8)
  : [];
---

<BaseLayout title={item.title} description={item.description}>

<nav class="breadcrumb">

<a href="/">トップ</a>

<span>›</span>

<a href="/illustration">イラスト一覧</a>

{item.category === "item" && item.tags?.[0] && (
<>
<span>›</span>

<a href={`/tag/${item.tags[0]}`}>
{item.tags[0]}
</a>

</>
)}

{item.category  !== "item" && (
<>
<span>›</span>

<a href="/illustration/character">
人物イラスト
</a>

{item.action && (
<>
<span>›</span>

<a href={`/illustration/action/${item.action}`}>
{item.action}
</a>

</>
)}

</>
)}

<span>›</span>

<span>{item.title}</span>

</nav>

<div class="illustration-page">

<img
src={item.png}
alt={item.title}
class="illustration-image"
/>

<div class="download-buttons">

<a href={item.png} download class="download-btn" data-format="png" data-slug={item.slug} data-title={item.title}>
⬇ PNGダウンロード
</a>

<a href={item.svg} download class="download-btn" data-format="svg" data-slug={item.slug} data-title={item.title}>
⬇ SVGダウンロード
</a>

{item.line_png && (
<a href={item.line_png} download class="download-btn" data-format="line_png" data-slug={item.slug} data-title={item.title}>
⬇ 線画PNG
</a>
)}

{item.line_svg && (
<a href={item.line_svg} download class="download-btn" data-format="line_svg" data-slug={item.slug} data-title={item.title}>
⬇ 線画SVG
</a>
)}

<h2 class="illustration-title">{item.title}</h2>

</div>

<p class="illustration-description">{item.description}</p>

<p class="illustration-license">
クレジット不要・商用利用可。
</p>

<ul class="usage-list">
<li>学校のおたより・掲示物に使えます。</li>
<li>Canva・PowerPoint・Wordで使用できます。</li>
<li>商用利用OK（クレジット不要）</li>
<li>素材の再配布は禁止です。</li>
</ul>

</div>

{samePose.length > 0 && (
<>

<hr />

<h2 class="section-title">このポーズの別表情</h2>

<div class="grid">
{samePose.map((i) => (
<a class="card" href={`/illustration/${i.slug}`}>
<img src={i.png} alt={i.title} />
</a>
))}
</div>

</>
)}


{sameTag.length > 0 && (
<>

<hr />

<h2 class="section-title">同じカテゴリのイラスト</h2>

<div class="grid">
{sameTag.map((i) => (
<a class="card" href={`/illustration/${i.slug}`}>
<img src={i.png} alt={i.title} />
</a>
))}
</div>

</>
)}


<script>
  declare function gtag(...args: unknown[]): void;

  document.querySelectorAll<HTMLAnchorElement>(".download-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
    console.log("---")
      gtag("event", "download", {
        file_format: btn.dataset.format,
        item_id: btn.dataset.slug,
        item_name: btn.dataset.title,
      });
    });
  });
</script>

</BaseLayout>