---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { illustrations } from "../../data/illustrations";

export function getStaticPaths() {
  return illustrations.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;

const samePose = illustrations.filter(
  (i) => i.pose === item.pose && i.slug !== item.slug
);
const sameAction = illustrations.filter(
  (i) => i.action === item.action && i.slug !== item.slug
);
---

<BaseLayout title={item.title} description={item.description}>
<nav class="breadcrumb">
  <a href="/">トップ</a> >
  <a href="/illustration">イラスト一覧</a> >
  <a href={`/illustration/action/${item.action}`}>{item.action}</a> >
  <span>{item.title}</span>
</nav>
<h2>{item.title}</h2>

<img
  src={item.png}
  alt={item.title}
  class="illustration-image"
/>

<p>{item.description}</p>

<p>PNG形式・背景透過。クレジット不要・商用利用可。</p>
<div class="download-buttons">
<a href={item.png} download>
⬇ PNGダウンロード
</a>
<a href={item.svg} download>
⬇ SVGダウンロード
</a>
</div>


<hr />

<h3>このポーズの別表情</h3>
<div class="grid">
  {samePose.map((i) => (
    <a class="card" href={`/illustration/${i.slug}`}>
      <img src={i.png} alt={i.title} />
    </a>
  ))}
</div>
<h3>同じシーンのイラスト</h3>

<div class="grid">
  {sameAction.map((i) => (
    <a class="card" href={`/illustration/${i.slug}`}>
      <img src={i.png} alt={i.title} />
    </a>
  ))}
</div>
</BaseLayout>