---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { illustrations  } from "../../../data/illustrations";
import IllustrationCard from "../../../components/IllustrationCard.astro";

const category  = illustrations .filter(
  (item) => !item.category.includes("item")
);
const itemIllustrations = illustrations
  .filter((i) => i.category.includes("item"))
  .slice(-8)
  .reverse();
const title = "人物イラスト一覧";
const description = "小学生の人物イラスト素材一覧です。";
---

<BaseLayout title={title} description={description}>

<h2 class="section-title">カテゴリ</h2>
<ul class="tag-list">
  <li><a href="/illustration/action/write_note">ノートを書く</a></li>
  <li><a href="/illustration/action/read_textbook">教科書を読む</a></li>
  <li><a href="/illustration/action/raise_hand">手を挙げる</a></li>
</ul>
<h2 class="section-title">人物イラスト</h2>
<div class="grid">
  {category .map((item) => (
    <IllustrationCard item={item} />
  ))}
</div>
<h2 class="section-title">アイテムイラスト</h2>
<div class="grid">
{itemIllustrations.map((item) => (
  <IllustrationCard item={item} />
))}
</div>
<a href="/illustration/item">
アイテムイラストをすべて見る
</a>

</BaseLayout>
