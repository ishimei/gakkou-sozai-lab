---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { illustrations  } from "../../../data/illustrations";
import IllustrationCard from "../../../components/IllustrationCard.astro";

export function getStaticPaths() {

  const category  = [
    ...new Set(
      illustrations
        .map((i) => i.character)
    ),
  ];

  return category .map((character) => ({
    params: { character },
  }));
}

const { character } = Astro.params;

const filtered = illustrations .filter(
  (i) => i.character === character
);

const title = `${character}のイラスト`;
const description = `小学校で使える${character}のフリーイラスト素材です。`;
---

<BaseLayout title={title} description={description}>

<h1>{title}</h1>

<div class="grid">
  {filtered.map((item) => (
    <IllustrationCard item={item} />
  ))}
</div>

</BaseLayout>
