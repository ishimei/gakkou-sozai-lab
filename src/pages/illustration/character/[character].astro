---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { illustrations  } from "../../../data/illustrations";

export function getStaticPaths() {

  const category  = [
    ...new Set(
      illustrations 
        .map((i) => i.character)
    ),
  ];

  return category .map((character) => ({
    params: { character },
  }));
}

const { character } = Astro.params;

const filtered = illustrations .filter(
  (i) => i.character === character
);

const title = `${character}のイラスト`;
const description = `小学校で使える${character}のフリーイラスト素材です。`;
---

<BaseLayout title={title} description={description}>

<h1>{title}</h1>

<div class="grid">
  {filtered.map((item) => (
    <a class="card" href={`/illustration/${item.slug}`}>
      <img src={item.png} alt={item.title} />
      <p>{item.title}</p>
    </a>
  ))}
</div>

</BaseLayout>