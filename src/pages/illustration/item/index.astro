---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { illustrations  } from "../../../data/illustrations";
import IllustrationCard from "../../../components/IllustrationCard.astro";

const items = illustrations .filter(
  (item) => item.character === "item"
);
const characterIllustrations = illustrations
  .filter((i) => i.character !== "item")
  .slice(-8);
const title = "学校の文房具イラスト";
const description = "小学校で使える文房具のフリーイラスト素材です。鉛筆・消しゴム・ランドセルなど。";
---

<BaseLayout title={title} description={description}>

<h2 class="section-title">カテゴリ</h2>
<ul class="tag-list">
<li><a href="/tag/鉛筆">鉛筆</a></li>
<li><a href="/tag/消しゴム">消しゴム</a></li>
<li><a href="/tag/ランドセル">ランドセル</a></li>
<li><a href="/tag/机">机</a></li>
<li><a href="/tag/椅子">椅子</a></li>
<li><a href="/tag/上履き">上履き</a></li>
<li><a href="/tag/上履き袋">上履き袋</a></li>
<li><a href="/tag/教科書">教科書</a></li>
</ul>
<h2 class="section-title">文房具イラスト</h2>
<div class="grid">
  {items.map((item) => (
    <IllustrationCard item={item} />
  ))}
</div>
<h2 class="section-title">人物イラスト</h2>
<div class="grid">
{characterIllustrations.map((item) => (
  <IllustrationCard item={item} />
))}
</div>
<a href="/illustration/character">人物イラスト一覧を見る</a>

</BaseLayout>
