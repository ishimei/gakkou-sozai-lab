---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { allIllustrations } from "../../../data/illustrations";

const items = allIllustrations.filter(
  (item) => item.character === "item"
);

const title = "学校の文房具イラスト";
const description = "小学校で使える文房具のフリーイラスト素材です。鉛筆・消しゴム・ランドセルなど。";
---

<BaseLayout title={title} description={description}>

<h1>{title}</h1>
<h2>学校アイテム</h2>
<ul>
<li><a href="/tag/鉛筆">鉛筆</a></li>
<li><a href="/tag/消しゴム">消しゴム</a></li>
<li><a href="/tag/ランドセル">ランドセル</a></li>
<li><a href="/tag/机">机</a></li>
<li><a href="/tag/椅子">椅子</a></li>
<li><a href="/tag/上履き">上履き</a></li>
<li><a href="/tag/上履き袋">上履き袋</a></li>
<li><a href="/tag/教科書">教科書</a></li>
</ul>
<h2>文房具イラスト</h2>
<div class="grid">
  {items.map((item) => (
    <a class="card" href={`/illustration/${item.slug}`}>
      <img src={item.png} alt={item.title} />
      <p>{item.title}</p>
    </a>
  ))}
</div>
<h2>人物イラスト</h2>
<a href="/illustration/character">人物イラスト一覧を見る</a>

</BaseLayout>