---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {allIllustrations} from "../../data/illustrations";

const title = "イラスト一覧";
const description = "小学校で使えるフリーイラスト素材の一覧ページ。";
---

<BaseLayout title={title} description={description}>
  <h2>ポーズ別イラスト</h2>

<ul>
  <li><a href="/illustration/action/write_note">ノートを書く</a></li>
  <li><a href="/illustration/action/read_textbook">教科書を読む</a></li>
  <li><a href="/illustration/action/raise_hand">手を挙げる</a></li>
</ul>

<h2>イラスト一覧</h2>

<div class="grid">
  {allIllustrations.map((item) => (
    <a href={`/illustration/${item.slug}`} class="card">
      <img src={item.png} alt={item.title} />
      <p>{item.title}</p>
    </a>
  ))}
</div>

</BaseLayout>