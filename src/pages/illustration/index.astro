---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { characterIllustrations, itemIllustrations } from "../../data/illustrations";
import IllustrationCard from "../../components/IllustrationCard.astro";

const title = "イラスト一覧";
const description = "小学校で使えるフリーイラスト素材のカテゴリ一覧ページ。";

const minLen = Math.min(characterIllustrations.length, itemIllustrations.length);
const interleaved = [
  ...Array.from({ length: minLen }, (_, i) => [characterIllustrations[i], itemIllustrations[i]]).flat(),
  ...characterIllustrations.slice(minLen),
  ...itemIllustrations.slice(minLen),
];

const PAGE_SIZE = 100;
const initial = interleaved.slice(0, PAGE_SIZE);
const rest = interleaved.slice(PAGE_SIZE);
---

<BaseLayout title={title} description={description}>

<h1>{title}</h1>

<div class="grid" id="grid">
  {initial.map((item) => (
    <IllustrationCard item={item} />
  ))}
</div>

{rest.length > 0 && (
  <div style="text-align:center; margin-top:24px;">
    <button id="load-more" class="load-more-btn">もっと見る</button>
  </div>
)}

</BaseLayout>

<script is:inline define:vars={{ rest }}>
  const btn = document.getElementById("load-more");
  if (btn) {
    btn.addEventListener("click", () => {
      const grid = document.getElementById("grid");
      rest.forEach((item) => {
        const a = document.createElement("a");
        a.className = "card";
        a.href = `/illustration/${item.slug}`;
        const badges = `<div class="card-badges">${item.line_png ? '<span class="card-badge card-badge--line">線画</span>' : ''}${item.svg ? '<span class="card-badge card-badge--svg">SVG</span>' : ''}</div>`;
        a.innerHTML = `${badges}<img src="${item.png}" alt="${item.title}" /><p>${item.title}</p>`;
        grid.appendChild(a);
      });
      btn.parentElement.remove();
    });
  }
</script>
